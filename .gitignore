# Generated data and run artifacts are large and reproducible — don't track them.
# Root-anchored on purpose: a bare `data/` also matches voxel_generator/data/, which holds
# ti_te_dict.mat — the acquisition protocol the code cannot run without.
/data/
/results/
# Python noise
__pycache__/
*.pyc
.pytest_cache/
.DS_Store
# The vendored generator's own outputs, if any get created here
voxel_generator/output/
/slurm/logs/*.out
